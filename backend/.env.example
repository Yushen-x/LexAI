# Copy this file to backend/.env and fill in your own configuration.
# The .env file is ignored by git and should never be committed.

# ---------- MySQL ----------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=lexai
MYSQL_USERNAME=lexai
MYSQL_PASSWORD=lexai_demo_2026

# ---------- Deli Open Platform (law / case search) ----------
DELI_APP_ID=
DELI_SECRET=

# ---------- Tencent Hunyuan / Chat Completions ----------
TENCENT_LLM_ENDPOINT=https://api.hunyuan.cloud.tencent.com/v1/chat/completions
TENCENT_LLM_API_KEY=
TENCENT_LLM_MODEL=hunyuan-lite

# ---------- Optional local knowledge base ----------
LEXAI_KNOWLEDGE_PATH=
LEXAI_KNOWLEDGE_INDEX_PATH=

# ---------- Runtime mode ----------
# Runtime mode:
# - tencent : Tencent Hunyuan + Deli retrieval
# - mock    : no external AI service
LEXAI_AI_MODE=tencent
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
