# 复制本文件为 backend/.env 并填入你自己的密钥（.env 已被 .gitignore 忽略，勿提交）
# 分步启动说明见：docs/后端本地启动与API环境配置.md

# ---------- 得理开放平台（法条 / 类案检索）----------
DELI_APP_ID=
DELI_SECRET=

# ---------- 腾讯大模型（OpenAI 兼容 Chat Completions 类 HTTP 接口）----------
TENCENT_LLM_ENDPOINT=
TENCENT_LLM_API_KEY=
TENCENT_LLM_MODEL=

# ---------- 可选：本地知识库目录（仓库内示例可用相对路径）----------
# 在 backend 目录执行 mvn 时，可设为项目根下的知识库目录，例如：
# LEXAI_KNOWLEDGE_PATH=../docs/knowledge-base
